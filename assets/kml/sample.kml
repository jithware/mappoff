    <Placemark>
      <name>Glen Ellis Falls Trailhead</name>
      <description>This historic site constructed by the Civilian Conservation Corps, offers a short hike to a dramatic 66 foot waterfall, picnicking opportunities, and is the starting point for those hiking the Glen Boulder or Wildcat trails.</description>
      <styleUrl>#icon-1596-558B2F</styleUrl>
